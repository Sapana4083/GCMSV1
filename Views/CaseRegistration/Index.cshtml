@model PagedResult<CaseRegistrationDto>
@{
    ViewData["Title"] = "Case Registration List";
}
<div class="page-title d-flex justify-content-between align-items-start gap-3">
    <div><h1>Case Registration List</h1><p>Search, sort, view, and maintain registered cases.</p></div>
    @if (User.IsInRole("Admin") || User.IsInRole("Registrar"))
    {
        <a asp-action="Create" class="btn btn-primary">New Registration</a>
    }
</div>
<form method="get" class="content-panel mb-3 list-filter">
    <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by case number, appellant, or linked case" />
    <button class="btn btn-outline-primary" type="submit">Search</button>
</form>
<div class="content-panel">
    <div class="table-responsive">
        <table id="caseTable" class="table table-striped table-hover align-middle">
            <thead><tr><th>Case Number</th><th>Institution Date</th><th>Appellant</th><th>Case Type</th><th>Department</th><th>Hearing Date</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.CaseNumber</td><td>@item.InstitutionDate.ToString("dd-MMM-yyyy")</td><td>@item.AppellantName</td><td>@item.CaseTypeName</td><td>@item.DepartmentName</td><td>@item.HearingDate.ToString("dd-MMM-yyyy")</td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">View</a> @if (User.IsInRole("Admin") || User.IsInRole("Registrar")) { <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a> }</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <nav class="pager-line">
        <span>Page @Model.PageNumber of @Model.TotalPages, @Model.TotalCount records</span>
        <div>
            @if (Model.PageNumber > 1) { <a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.PageNumber - 1)" asp-route-search="@ViewBag.Search">Previous</a> }
            @if (Model.PageNumber < Model.TotalPages) { <a class="btn btn-sm btn-outline-secondary" asp-route-page="@(Model.PageNumber + 1)" asp-route-search="@ViewBag.Search">Next</a> }
        </div>
    </nav>
</div>
