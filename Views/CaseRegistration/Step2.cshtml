@model CaseRegistrationWizardViewModel
@{
    ViewData["Title"] = "Appellant Details";
}
<input asp-for="Id" type="hidden" />
<div class="page-title"><h1>Appellant Details</h1><p>Step 2 of 4</p></div>
<div class="card shadow-sm border-0">
<div class="card-body">
<div class="wizard"><span>1 Basic</span><span class="active">2 Appellant</span><span>3 Respondent</span><span>4 Private Party</span></div>
<form asp-action="Step2" method="post" class="content-panel">
    @Html.AntiForgeryToken()<input asp-for="Id" type="hidden" />
    <div class="row g-3">
        <div class="col-md-4"><label asp-for="AppellantName" class="form-label"></label><input asp-for="AppellantName" class="form-control" /><span asp-validation-for="AppellantName" class="text-danger"></span></div>
                <div class="col-md-4">
                    <label asp-for="DesignationId" class="form-label"></label>

                    <select asp-for="DesignationId"
                            asp-items="Model.Designations"
                            class="form-select">
                        <option value="">-- Select Designation --</option>
                    </select>

                    <span asp-validation-for="DesignationId" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="DistrictId" class="form-label"></label>

                    <select asp-for="DistrictId"
                            asp-items="Model.Districts"
                            class="form-select">
                        <option value="">-- Select District --</option>
                    </select>

                    <span asp-validation-for="DistrictId" class="text-danger"></span>
                </div>
                <div class="col-md-4"><label asp-for="MobileNumber" class="form-label"></label><input asp-for="MobileNumber" class="form-control" /><span asp-validation-for="MobileNumber" class="text-danger"></span></div>
                <div class="col-md-4">
                    <label asp-for="AdvocateId" class="form-label"></label>

                    <select asp-for="AdvocateId"
                            asp-items="Model.Advocates"
                            class="form-select">
                        <option value="">-- Select Advocate --</option>
                    </select>

                    <span asp-validation-for="AdvocateId" class="text-danger"></span>
                </div>
                <div class="col-md-4"><label asp-for="AdvocateEmail" class="form-label"></label><input asp-for="AdvocateEmail" class="form-control" /><span asp-validation-for="AdvocateEmail" class="text-danger"></span></div>
        <div class="col-md-4"><label asp-for="AdvocateMobile" class="form-label"></label><input asp-for="AdvocateMobile" class="form-control" /><span asp-validation-for="AdvocateMobile" class="text-danger"></span></div>
                <div class="col-md-4">
                    <label asp-for="EmployeeId" class="form-label"></label>

                    <input asp-for="EmployeeId"
                           class="form-control" />

                    <span asp-validation-for="EmployeeId"
                          class="text-danger"></span>
                </div>
    </div>
            <div class="form-actions">
                <a asp-action="Step1"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-secondary">
                    Back
                </a>
            @* <button type="submit" name="navigation" value="Back" class="btn btn-outline-primary cancel" formnovalidate>Back</button> *@
                <button type="submit" name="navigation" value="Next" class="btn btn-primary">Next</button>
            </div>
</form>
</div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }


