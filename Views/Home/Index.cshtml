@model List<CourtDashboardViewModel>
@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~\css\all.min.css" rel="stylesheet" />
<style>

    body {
        /* background: #f5f7fb; */
        font-family: 'Segoe UI',sans-serif;
    }

    .dashboard-wrapper {
        max-width: 1400px;
        margin: auto;
        padding: 30px;
    }

    .page-title {
        text-align: center;
        font-size: 45px;
        font-weight: 700;
        color: #123b88;
        margin-bottom: 50px;
        letter-spacing: 2px;
        text-shadow: 0px 4px 3px rgb(0 0 0 / 28%), 0px 8px 13px rgba(0, 0, 0, 0.1), 0px 18px 23px rgba(0, 0, 0, 0.1);
    }

    .section-title {
        display: flex;
        align-items: center;
        margin: 45px 0 25px;
    }

        .section-title::before,
        .section-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: #d9d9d9;
        }

        .section-title span {
            margin: 0 20px;
            color: #12439b;
            font-size: 34px;
            font-weight: 700;
        }

    .dashboard-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 18px rgba(0,0,0,.12);
        transition: .35s;
        border-top: 5px solid;
    }

        .dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 35px rgba(0,0,0,.18);
            cursor:pointer;
        }

    .blue {
        border-color: #2563eb;
    }

    .red {
        border-color: #ef4444;
    }

    .green {
        border-color: #16a34a;
    }

    .cyan {
        border-color: #06b6d4;
    }

    .card-body {
        display: flex;
        align-items: center;
        padding: 28px 22px;
    }

    .icon-box {
        width: 82px;
        height: 82px;
        border-radius: 18px;
        display: flex;
        justify-content: center;
        align-items: center;
        margin-right: 18px;
        font-size: 38px;
    }

    .blue .icon-box {
        background: #edf3ff;
        color: #2563eb;
    }

    .red .icon-box {
        background: #fff1f1;
        color: #ef4444;
    }

    .green .icon-box {
        background: #eefcf4;
        color: #16a34a;
    }

    .cyan .icon-box {
        background: #eefcff;
        color: #06b6d4;
    }

    .card-number {
        font-size: 46px;
        font-weight: 700;
        line-height: 1;
        text-shadow: 0px 4px 3px rgb(0 0 0 / 15%), 0px 8px 13px rgba(0, 0, 0, 0.1), 0px 18px 23px rgba(0, 0, 0, 0.1);
    }

    .blue .card-number {
        color: #2563eb;
    }

    .red .card-number {
        color: #ef4444;
    }

    .green .card-number {
        color: #16a34a;
    }

    .cyan .card-number {
        color: #06b6d4;
    }

    .card-text {
        margin-top: 8px;
        font-size: 18px;
        font-weight: 600;
        color: #333;
    }

    .card-footer {
        background: #fff;
        border-top: 1px solid #ececec;
        padding: 15px 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .card-footer a {
            text-decoration: none;
            color: #12439b;
            font-weight: 600;
        }

        .card-footer i {
            color: #12439b;
        }

    @@media(max-width:768px) {

        .page-title {
            font-size: 34px;
        }

        .section-title span {
            font-size: 24px;
        }

        .card-number {
            font-size: 34px;
        }

        .card-text {
            font-size: 15px;
        }
    }

</style>

<div class="dashboard-wrapper">

    <h1 class="page-title">
        WELCOME TO RCSAT
    </h1>

    @foreach (var court in Model)
    {

        <div class="section-title">
            <span>@court.CourtName.ToUpper()</span>
        </div>

        <div class="row g-4 mb-5">

            <div class="col-lg-3 col-md-6">

                <div class="dashboard-card blue">

                    <div class="card-body">

                        <div class="icon-box">
                            <i class="bi bi-reception-4"></i>
                        </div>

                        <div>
                            <div class="card-number">
                                @court.RegisteredCases
                            </div>

                            <div class="card-text">
                                Total Registration
                            </div>
                        </div>

                    </div>

                    <div class="card-footer">

                        <a href="#">View All</a>

                        <i class="fas fa-arrow-right"></i>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="dashboard-card red">

                    <div class="card-body">

                        <div class="icon-box">
                            <i class="bi bi-reception-3"></i>
                        </div>

                        <div>
                            <div class="card-number">
                                @court.PendingCases
                            </div>

                            <div class="card-text">
                                Total Pending Cases
                            </div>
                        </div>

                    </div>

                    <div class="card-footer">

                        <a href="#">View All</a>

                        <i class="fas fa-arrow-right"></i>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="dashboard-card green">

                    <div class="card-body">

                        <div class="icon-box">
                            <i class="bi bi-reception-2"></i>
                        </div>

                        <div>
                            <div class="card-number">
                                @court.Decided
                            </div>

                            <div class="card-text">
                                Total Decided Cases
                            </div>
                        </div>

                    </div>

                    <div class="card-footer">

                        <a href="#">View All</a>

                        <i class="fas fa-arrow-right"></i>

                    </div>

                </div>

            </div>

            <div class="col-lg-3 col-md-6">

                <div class="dashboard-card cyan">

                    <div class="card-body">

                        <div class="icon-box">
                            <i class="bi bi-person-fill"></i>
                        </div>

                        <div>
                            <div class="card-number">
                                @court.Users
                            </div>

                            <div class="card-text">
                                Total Users
                            </div>
                        </div>

                    </div>

                    <div class="card-footer">

                        <a href="#">View All</a>

                        <i class="fas fa-arrow-right"></i>

                    </div>

                </div>

            </div>

        </div>

    }

</div>