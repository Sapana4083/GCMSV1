@model List<GCMS.Models.DistrictMaster>

@{
    ViewData["Title"] = "District Master";
    var states = ViewBag.StateList as List<GCMS.Models.StateMaster>;
    var divisions = ViewBag.DivisionList as List<GCMS.Models.DivisionMaster>;
}
<div class="container-fluid bg-light rounded-4 shadow m-3 py-4 px-3">
    <div class="d-flex justify-content-between mb-3 border-bottom border-3 pb-3">
        <h4>District Master</h4>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" id="btnAddDistrict">
                Add District
            </button>

            <button class="btn btn-secondary" id="btnPrint">
                <i class="bi bi-printer-fill"></i>
            </button>

            <button class="btn btn-success" id="btnExcel">
                <i class="bi bi-file-earmark-excel"></i>
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-striped" id="tblDistrict">

            <thead>
                <tr>
                    <td width="50">S. No.</td>
                    <th>District Name</th>
                    <th>District Code</th>
                    <th>State</th>
                    <th>Division</th>
                    <th>English Name</th>
                    <th>Abbreviation</th>
                    <th>Hindi Name</th>
                    <th>Active</th>
                    <th width="170">Action</th>
                </tr>
            </thead>

            <tbody>

                @{
                    int i = 1;
                }

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@i</td>

                        <td>@item.DistrictName</td>

                        <td>@item.DistrictCode</td>

                        <td>
                            @(states?
                            .FirstOrDefault(x => x.StateMastId == item.StateName)?
                            .StateName)
                        </td>

                        <td>
                            @(divisions?
                            .FirstOrDefault(x => x.DivisionMastId == item.DivisionName)?
                            .DivisionName)
                        </td>

                        <td>@item.DistrictNameEng</td>

                        <td>@item.DistAbr</td>

                        <td>@item.DistNameHinEng</td>
                        <td>
                            @if (item.InActive == "F")
                            {
                                <span class="badge bg-success">
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    Inactive
                                </span>
                            }
                        </td>
                        <td>

                            <button class="btn btn-default waves-effect waves-light edit"
                                    data-id="@item.DistrictMastId">
                                Edit
                            </button>

                        </td>

                    </tr>

                    i++;
                }

            </tbody>
        </table>
    </div>
</div>
<div class="modal fade"
     id="districtModal"
     tabindex="-1">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h5 class="modal-title">
                    District Master
                </h5>

                <button class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <input type="hidden"
                       id="DistrictMastId" />

                <div class="row">

                    <div class="col-md-6 mb-3">

                        <label>District Name</label>

                        <input id="DistrictName"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>District Code</label>

                        <input id="DistrictCode"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>State</label>

                        <select id="StateName"
                                class="form-select">

                            <option value="">
                                Select State
                            </option>

                            @foreach (var s in states)
                            {
                                <option value="@s.StateMastId">
                                    @s.StateName
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>Division</label>

                        <select id="DivisionName"
                                class="form-select">

                            <option value="">
                                Select Division
                            </option>

                            @foreach (var d in divisions)
                            {
                                <option value="@d.DivisionMastId">
                                    @d.DivisionName
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>District English Name</label>

                        <input id="DistrictNameEng"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>District Abbreviation</label>

                        <input id="DistAbr"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-3">

                        <label>English - Hindi Name</label>

                        <input id="DistNameHinEng"
                               class="form-control" />

                    </div>
                    <div class="col-md-6 mb-3">

                        <label>In Active</label>

                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" id="InActive">
                            <label class="form-check-label">Disable</label>
                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Close
                </button>

                <button class="btn btn-success"
                        id="btnSave">
                    Save
                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script>

        $(function () {

            // ── Init ─────────────────────────────────────────────
            $(document).ready(function () {

                $('#tblDistrict').DataTable({

                    dom: 'lBfrtip',

                    responsive: true,
                    autoWidth: false,

                    pageLength: 10,

                    lengthMenu: [
                        [10, 25, 50, 100],
                        [10, 25, 50, 100]
                    ],

                    paging: true,
                    searching: true,
                    ordering: true,
                    info: true,

                    columnDefs: [{
                        responsivePriority: 1,
                        targets: 7
                    },
                    {
                        responsivePriority: 2,
                        targets: 0
                    }
                    ],

                    buttons: [{
                        extend: 'print',
                        title: 'District Master'
                    },
                    {
                        extend: 'excelHtml5',
                        title: 'District Master'
                    }
                    ]
                });

                $('.dt-buttons').hide();
            });
            $("#btnPrint").click(function () {

                window.print();

            });

            $("#btnExcel").click(function () {

                let table = document.getElementById("tblState");

                let html = table.outerHTML;

                let url = 'data:application/vnd.ms-excel,' +
                    encodeURIComponent(html);

                let a = document.createElement('a');

                a.href = url;
                a.download = 'District.xls';

                a.click();

            });

            var modal =
                new bootstrap.Modal(
                    document.getElementById("districtModal"));

            $("#btnAddDistrict").click(function () {

                $("#DistrictMastId").val("");
                $("#DistrictName").val("");
                $("#DistrictCode").val("");
                $("#StateName").val("");
                $("#DivisionName").val("");
                $("#DistrictNameEng").val("");
                $("#DistAbr").val("");
                $("#DistNameHinEng").val("");
                $("#InActive").val("");

                modal.show();

            });

            $(document).on("click", ".edit", function () {

                var id = $(this).data("id");

                console.log("District Id:", id);

                $.ajax({
                    url: "/Master/GetDistrict",
                    type: "GET",
                    data: { id: id },

                    success: function (data) {

                        console.log(data);

                        if (data == null) {
                            alert("No data returned from server");
                            return;
                        }

                        $("#DistrictMastId").val(data.districtMastId);
                        $("#DistrictName").val(data.districtName);
                        $("#DistrictCode").val(data.districtCode);
                        $("#StateName").val(data.stateName);
                        $("#DivisionName").val(data.divisionName);
                        $("#DistrictNameEng").val(data.districtNameEng);
                        $("#DistAbr").val(data.distAbr);
                        $("#DistNameHinEng").val(data.distNameHinEng);
                        $("#inActive").val(data.inActive);

                        modal.show();
                    },

                    error: function (xhr) {
                        console.log(xhr.responseText);
                        alert("Error loading district.");
                    }
                });

            });

            $("#btnSave").click(function () {

                $.ajax({

                    url: '/Master/SaveDistrict',

                    type: 'POST',

                    data: {

                        DistrictMastId: $("#DistrictMastId").val(),

                        DistrictName: $("#DistrictName").val(),

                        DistrictCode: $("#DistrictCode").val(),

                        StateName: $("#StateName").val(),

                        DivisionName: $("#DivisionName").val(),

                        DistrictNameEng: $("#DistrictNameEng").val(),

                        DistAbr: $("#DistAbr").val(),

                        DistNameHinEng: $("#DistNameHinEng").val(),

                        InActice: $("#InActive").val()

                    },

                    success: function (r) {

                        if (r.success) {

                            location.reload();

                        }
                        else {

                            alert(r.message);

                        }

                    }

                });

            });

            $(document).on("click", ".delete", function () {

                if (!confirm("Are you sure?"))
                    return;

                var id = $(this).data("id");

                $.post("/Master/DeleteDistrict",
                    { id: id },
                    function () {

                        location.reload();

                    });

            });

        });

    </script>
}