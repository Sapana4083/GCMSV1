<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GCMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link href="~/css/jquery.datatables.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebarstylesheet.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="~/GCMS.styles.css" asp-append-version="true" />
    <link href="~/lib/bootstrap-icon/font/bootstrap-icons-new.css" rel="stylesheet" />
    <link rel="stylesheet"
          href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.dataTables.min.css" />
    <link rel="stylesheet"
          href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <a href="#mainContent" class="skip-to-content">Skip to main content</a>

    <div class="accessibility-bar" role="region" aria-label="Accessibility options">
        <div class="container-fluid d-flex justify-content-end align-items-center gap-2 py-1">
            <span class="accessibility-label">Text Size:</span>
            <button type="button" class="a11y-btn" id="fontDecrease" aria-label="Decrease text size">A-</button>
            <button type="button" class="a11y-btn" id="fontReset" aria-label="Reset text size">A</button>
            <button type="button" class="a11y-btn" id="fontIncrease" aria-label="Increase text size">A+</button>

            <span class="accessibility-divider" aria-hidden="true">|</span>

            <button type="button" class="a11y-btn" id="contrastToggle" aria-pressed="false">
                High Contrast
            </button>

            <button type="button" class="a11y-btn" id="spacingToggle" aria-pressed="false">
                Text Spacing
            </button>
        </div>
    </div>

    <div class="d-flex" id="wrapper">

        <!-- ===========================
             SIDEBAR
        =========================== -->
        <nav class="sidebar" id="sidebar">

            <div class="sidebar-header">
                <i class="bi bi-grid-1x2-fill fs-5 text-primary"></i>
                <span class="brand-text">GCMS</span>
            </div>

            <ul class="nav flex-column py-2">

                <li class="nav-item">
                    <a class="nav-link @(string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span class="link-text">Home</span>
                    </a>
                </li>

                <!-- LEVEL 1: Masters -->
                <li class="nav-item dd-parent">
                    <a class="nav-link dropdown-toggle @(string.Equals(currentController, "Master", StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                       href="#"
                       id="sidebarMastersDropdown">
                        <i class="bi bi-clipboard2-minus-fill"></i>
                        <span class="link-text">Masters</span>
                        <i class="bi bi-chevron-down caret"></i>
                    </a>

                    <ul class="dropdown-menu">

                        <!-- LEVEL 2: Common Master -->
                        <li class="dropdown-submenu dd-parent">
                            <a href="#" class="dropdown-item dropdown-toggle">
                                <i class="bi bi-folder"></i>
                                <span class="link-text">Common Master</span>
                                <i class="bi bi-chevron-right caret"></i>
                            </a>

                            <ul class="dropdown-menu">

                                <!-- LEVEL 3: Location Master -->
                                <li class="dropdown-submenu dd-parent">
                                    <a href="#" class="dropdown-item dropdown-toggle">
                                        <i class="bi bi-geo-alt"></i>
                                        <span class="link-text">Location Master</span>
                                        <i class="bi bi-chevron-right caret"></i>
                                    </a>

                                    <ul class="dropdown-menu">
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Master"
                                               asp-action="StateList">
                                                State
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Master"
                                               asp-action="DivisionList">
                                                Division
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Master"
                                               asp-action="DistrictList">
                                                District
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Master"
                                               asp-action="SdoList">
                                                SDO
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="Master"
                                               asp-action="TehsilList">
                                                Tehsil
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                                <!-- end LEVEL 3 -->

                            </ul>
                        </li>
                        <!-- end Common Master -->
                        <!-- LEVEL 2: User Master -->
                        <li class="dropdown-submenu dd-parent">
                            <a href="#" class="dropdown-item dropdown-toggle">
                                <i class="bi bi-person-gear"></i>
                                <span class="link-text">User Master</span>
                                <i class="bi bi-chevron-right caret"></i>
                            </a>

                            <ul class="dropdown-menu">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="UserMaster"
                                       asp-action="UserLogin">
                                        Login User
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </li>
                <!-- end Masters -->

                <li class="nav-item">
                    <a class="nav-link @(string.Equals(currentController, "CaseRegistration", StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                       asp-controller="CaseRegistration"
                       asp-action="Step1">
                        <i class="bi bi-journal-plus"></i>
                        <span class="link-text">Case Registration</span>
                    </a>
                </li>

            </ul>
        </nav>

        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- ===========================
             CONTENT AREA
        =========================== -->
        <div class="content-area" id="contentArea">

            <header class="topbar">
                <button class="sidebar-toggle-desktop" id="sidebarToggle" type="button" aria-label="Collapse sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <button class="sidebar-toggle-mobile" id="sidebarToggleMobile" type="button" aria-label="Open sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </header>

            <main role="main" class="pb-3" id="mainContent" tabindex="-1">
                @RenderBody()
            </main>

            @* <footer class="border-top footer text-muted bg-light">
                <div class="container-fluid">
                    &copy; 2026 - GCMS.WEB - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer> *@

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/jquery.datatables.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sidebarjavascript.js" asp-append-version="true"></script>
    <script src="~/js/accessibility.js" asp-append-version="true"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
