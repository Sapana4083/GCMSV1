<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GCMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebarstylesheet.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GCMS.styles.css" asp-append-version="true" />
    <link href="~/lib/bootstrap-icon/font/bootstrap-icons-new.css" rel="stylesheet" />
</head>
<body>

    <div class="d-flex" id="wrapper">
        <header>
            <!-- Sidebar -->
            <nav class="sidebar" id="sidebar">
                <div class="sidebar-header">
                    <a class="navbar-brand" href="#">
                        <span class="logo-mark">G</span>
                        <span class="logo-text">GCMS</span>
                    </a>
                    <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Toggle sidebar" aria-expanded="true">
                        <i class="bi bi-list"></i>
                    </button>
                </div>
                @{
                    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                }

                <ul class="nav flex-column sidebar-nav">
                    <li class="nav-item">
                        <a class="nav-link text-dark @(string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="Index">
                            <i class="bi bi-house-door"></i><span class="link-text">Home</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark @(string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) && string.Equals(currentAction, "Privacy", StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                           asp-area=""
                           asp-controller="Home"
                           asp-action="Privacy">
                            <i class="bi bi-shield-lock"></i><span class="link-text">Privacy</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </header>
        <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

        <!-- Main content -->
        <div class="content-area" id="contentArea">
            <header class="topbar">
                <button class="sidebar-toggle-mobile" id="sidebarToggleMobile" type="button" aria-label="Open sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <span class="topbar-title">GCMS</span>
            </header>

            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

    </div>
    <footer class="border-top footer text-muted bg-light">
        <div class="container">
            &copy; 2026 - GCMS.WEB - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    @* <div class="container-fluid">
        <div class="row">
            <div class="col-12 py-3">
                <p class="text-center">
                    <span class="fw-bold">
                        Court :
                    </span>
                    <span class="fw-bold fs-3">@Context.Session.GetString("CourtName")</span>
                </p>
            </div>
            <div class="col-6">
                <p class="text-end">
                    <span class="fw-bold">
                        Department :
                    </span>
                    <span class="text-decoration-underline">@Context.Session.GetString("DepartmentName")</span>
                </p>
            </div>
        </div>
    </div> *@
    @* <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GCMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GCMS.WEB - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sidebarjavascript.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
